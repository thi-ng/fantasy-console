{
	"name": "@thi.ng/fantasy-console",
	"version": "1.0.0",
	"description": "Browser-based TIC-80 inspired fantasy console for workshops/educational purposes, written in TypeScript and using thi.ng/umbrella",
	"repository": "https://github.com/thi-ng/fantasy-console",
	"author": "Karsten Schmidt (https://thi.ng)",
	"license": "MIT",
	"type": "module",
	"scripts": {
		"start": "vite --open",
		"build": "tsc && vite build --base='./'",
		"preview": "vite preview --host --open"
	},
	"devDependencies": {
		"typescript": "^6.0.3",
		"vite": "^8.0.14",
		"vite-plugin-html": "^3.2.2"
	},
	"dependencies": {
		"@thi.ng/api": "^8.12.25",
		"@thi.ng/binary": "^3.6.14",
		"@thi.ng/checks": "^3.9.5",
		"@thi.ng/dl-asset": "^2.3.145",
		"@thi.ng/grid-iterators": "^4.0.167",
		"@thi.ng/math": "^5.15.14",
		"@thi.ng/pixel": "^7.5.34",
		"@thi.ng/random": "^4.1.51",
		"@thi.ng/resolve-map": "^7.1.137",
		"@thi.ng/strings": "^3.12.7"
	},
	"browsersList": [
		"last 3 chrome versions"
	],
	"browser": {
		"process": false
	},
	"keywords": [
		"thing-umbrella",
		"typescript"
	]
}
